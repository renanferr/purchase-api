# ==================
# DATABASE CONFIGURATION
# ==================
# PostgreSQL connection string
# Format: postgres://user:password@host:port/database?sslmode=disable
# For local development:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/purchase_api?sslmode=disable

# For production, use environment-specific values:
# DATABASE_URL=postgres://dbuser:PRODUCTION_PASSWORD@db.example.com:5432/purchase_api?sslmode=require

# ==================
# API CONFIGURATION
# ==================
# HTTP server port (default: 8080)
API_PORT=8080

# ==================
# LOGGING CONFIGURATION
# ==================
# Log level: DEBUG, INFO (default), WARN, ERROR
# Use DEBUG for development, INFO for staging, WARN for production
LOG_LEVEL=INFO

# ==================
# EXTERNAL SERVICE CONFIGURATION
# ==================
# Treasury service API endpoint (for exchange rates)
# Default: https://www.treasurydirect.gov (US Treasury API)
TREASURY_API_URL=https://www.treasurydirect.gov

# ==================
# TIMEOUTS
# ==================
# HTTP timeout in seconds (for external service calls)
HTTP_TIMEOUT_SECONDS=10

# Server shutdown timeout in seconds
SHUTDOWN_TIMEOUT_SECONDS=30

# ==================
# NOTES FOR DEVELOPERS
# ==================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Update values in .env with your local configuration
#
# 3. NEVER commit .env file - it's in .gitignore
#    .env.example is committed as a template
#
# 4. For local Docker development:
#    - DATABASE_URL should point to docker postgres service
#    - Run: docker compose up -d
#    - Then: go run ./cmd/migrate/main.go
#
# 5. For production deployments:
#    - Use strong passwords
#    - Use sslmode=require for database
#    - Set LOG_LEVEL=WARN or ERROR
#    - Use environment-specific API URLs
